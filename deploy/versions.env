# Pinned versions for a reproducible shopgym StateFork demo bring-up.
# Edit these to move the demo node to a different commit. The SHAs below are the
# exact commits the demo was last verified against (2026-07-01).

# This control-plane repo. The deploy script does NOT re-checkout it (you already
# cloned it to run the script); it only checks you are on this ref and warns if not.
WEBDEMO_URL="git@github.com:AndyGE44/Branching_Webdemo.git"
WEBDEMO_REF="9373dec098e7a7423ee040500b01f1dcf2864b76"   # branch main (current HEAD)

# StateFork controller (imported by the control plane as DEMO_STATEFORK_ROOT).
# Alex-XJK is now the active line (the AndyGE44/Andy_* forks are retired). The
# webdemo was last validated against Andy_StateFork d9f36b0 — keep that as the
# fallback if Alex's StateFork API has drifted (symptoms show at build/checkpoint).
STATEFORK_URL="git@github.com:Alex-XJK/StateFork.git"
STATEFORK_REF="1b2cd4b1a88c42397e59a7998997b58aa99f0fd1"  # branch main

# Waypoint backend. MUST be a ref carrying the Node-friendly CRIU dump flags
# (--force-irmap / --link-remap in pkg/waypoint/memory.go) or shop checkpoints
# fail. NOTE: Alex-XJK/waypoint `main` (4eeb4cc) does NOT carry them; the flags
# live on `feature/session-isolation` (verified present at 3208079), so pin that.
# Fallback (last webdemo-validated): AndyGE44/Andy_Waypoint b3ff442.
WAYPOINT_URL="git@github.com:Alex-XJK/waypoint.git"
WAYPOINT_REF="320807936f997235213bc0c22d8bc5404214bf72"   # branch feature/session-isolation

# Where the shopgym data + image archive lives. Default = the CloudLab project
# NFS. On any OTHER node (e.g. EC2) there is no /proj NFS, so download the archive
# (the 4 zips + restore.sh + shopgym.sh, ~3.2 GB) from your private S3 bucket and
# override, e.g. SHOPGYM_SRC=$HOME/shopgym-src ./deploy/deploy.sh
SHOPGYM_SRC="/proj/cuserverless-PG0/share/shopgym"

# Where to clone the sibling repos (the launcher defaults expect $HOME/Andy_*).
DEPLOY_WORKDIR="${DEPLOY_WORKDIR:-$HOME}"
