# Pinned versions for a reproducible shopgym StateFork demo bring-up.
# Edit these to move the demo node to a different commit.
#
# All three repos are PUBLIC and clone over HTTPS, so a fresh node needs no
# ssh-agent forwarding. (Don't reintroduce SSH URLs casually: a forwarded agent
# socket disappears when the operator's SSH session reconnects, which kills a
# long deploy mid-clone.)
#
# The sibling repos land in $DEPLOY_WORKDIR as `StateFork` / `waypoint`. Those
# names are deliberately owner-neutral — the old `Andy_*` names encoded the fork
# owner and went stale the moment the active fork moved to Alex-XJK.

# This control-plane repo. The deploy script does NOT re-checkout it (you already
# cloned it to run the script).
WEBDEMO_URL="https://github.com/AndyGE44/Branching_Webdemo.git"
# Last commit the EC2 deploy was verified end-to-end against (build, CRIU
# snapshot/restore, and add-to-cart through the public URL). deploy.sh only warns
# if your checkout does NOT contain this commit; being ahead of it is normal.
WEBDEMO_REF="a7eed05819dec6e1d27f28744e760775ec297e8f"   # branch main

# StateFork controller (imported by the control plane as DEMO_STATEFORK_ROOT).
# Alex-XJK is the active line; the AndyGE44/Andy_* forks are retired.
# Fallback if Alex's StateFork API drifts (symptoms show at build/checkpoint):
#   https://github.com/AndyGE44/Andy_StateFork.git @ d9f36b0
STATEFORK_URL="https://github.com/Alex-XJK/StateFork.git"
STATEFORK_REF="1b2cd4b1a88c42397e59a7998997b58aa99f0fd1"  # branch main

# Waypoint backend. MUST be a ref carrying the Node-friendly CRIU dump flags
# (--force-irmap / --link-remap in pkg/waypoint/memory.go) or shop checkpoints
# fail. NOTE: Alex-XJK/waypoint `main` (4eeb4cc) does NOT carry them; the flags
# live on `feature/session-isolation` (verified present at 3208079) — pin that.
# Fallback (last Andy-era validated): https://github.com/AndyGE44/Andy_Waypoint.git @ b3ff442
WAYPOINT_URL="https://github.com/Alex-XJK/waypoint.git"
WAYPOINT_REF="320807936f997235213bc0c22d8bc5404214bf72"   # branch feature/session-isolation

# Where the shopgym data + image archive lives. Default = the CloudLab project
# NFS. On any OTHER node (e.g. EC2) there is no /proj NFS: copy the archive in
# (the 4 zips + restore.sh + shopgym.sh, ~3.2 GB — restore.sh rebuilds the rest)
# and override by pre-setting SHOPGYM_SRC, e.g.
#   SHOPGYM_SRC=$HOME/shopgym-src ./deploy/deploy.sh
# The ${SHOPGYM_SRC:-...} form is what makes that override work: deploy.sh
# *sources* this file, so a bare assignment would clobber the exported value.
SHOPGYM_SRC="${SHOPGYM_SRC:-/proj/cuserverless-PG0/share/shopgym}"

# Where to clone the sibling repos (the launcher defaults expect $HOME/StateFork
# and $HOME/waypoint).
DEPLOY_WORKDIR="${DEPLOY_WORKDIR:-$HOME}"
