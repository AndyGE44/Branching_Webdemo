# Copy to .env on the VM and fill in a real password before public demos.
TOY_DEMO_AUTH_USER=demo
TOY_DEMO_AUTH_PASSWORD=replace-with-a-demo-password

# Shared VM / StateFork defaults.
TOY_BRANCH_BACKEND=statefork
TOY_STATEFORK_ROOT=/users/alexxjk/StateFork
TOY_STATEFORK_CWD=/users/alexxjk/StateFork
TOY_STATEFORK_METHOD=ckpt_build
CHECKPOINT_SESSIONS_DIR=/tmp/checkpoint-sessions
TOY_BRANCH_HOST=127.0.0.1
TOY_BRANCH_PORT_START=8300

# Main app bind address for Cloudflare Tunnel.
TOY_MAIN_HOST=127.0.0.1
TOY_MAIN_PORT=8000
