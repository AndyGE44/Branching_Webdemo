# Copy to .env on the VM and fill in a real password before public demos.
DEMO_AUTH_USER=demo
DEMO_AUTH_PASSWORD=replace-with-a-demo-password

# Shared VM / StateFork defaults.
DEMO_STATEFORK_ROOT=/users/alexxjk/StateFork
DEMO_STATEFORK_CWD=/users/alexxjk/StateFork
DEMO_STATEFORK_METHOD=ckpt_build
CHECKPOINT_SESSIONS_DIR=/tmp/checkpoint-sessions
DEMO_BRANCH_HOST=127.0.0.1
DEMO_BRANCH_PORT_START=8300

# Selected app-plane app. The control-plane UI can also switch apps at runtime.
DEMO_APP_ID=email
DEMO_MAILBOX_DB_PATH=demo_mailbox.db
DEMO_INVENTORY_DB_PATH=demo_inventory.db

# Inventory data tier backend (architecture B vs A).
#   sqlite (default): DB file lives inside the StateFork checkpoint.
#   dolt: external Dolt repo, CLI-driven (one `dolt` process per query). Simple,
#         but slow steady state. Requires the `dolt` CLI on PATH.
#   dolt_server: external Dolt served by a long-lived `dolt sql-server` over the
#         MySQL protocol (pooled connections, realistic perf). Versioning uses
#         CALL DOLT_* procedures. Requires `dolt` on PATH and PyMySQL installed.
DEMO_INVENTORY_DB_BACKEND=sqlite
# Used by dolt / dolt_server; keep OUTSIDE the branch workdir so the app
# checkpoint does not capture it.
# DEMO_INVENTORY_DOLT_DIR=/tmp/demo_inventory_dolt
# dolt_server connection (the control plane starts the server on this port).
# DEMO_INVENTORY_DOLT_HOST=127.0.0.1
# DEMO_INVENTORY_DOLT_PORT=3306
# DEMO_INVENTORY_DOLT_DB=demo_inventory_dolt   # defaults to the repo dir name

# Runtime target override for low-level debugging. Normally use DEMO_APP_ID.
# DEMO_APP_UVICORN_TARGET=agent_safe_demo.app_plane.email_service.app:app

# Main app bind address for Cloudflare Tunnel.
DEMO_MAIN_HOST=127.0.0.1
DEMO_MAIN_PORT=8000
