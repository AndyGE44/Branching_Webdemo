# Copy to .env and fill in a strong password before any public demo.
# The control plane runs as root (CRIU/podman), so never expose it unauthenticated.

# Basic Auth on the whole control plane (login prompt covers the embedded shops too).
# REQUIRED for the public tunnel demo. Use a long random value, e.g.: openssl rand -base64 18
DEMO_AUTH_USER=demo
DEMO_AUTH_PASSWORD=replace-with-a-strong-password

# Bind LOCALHOST ONLY (also the launcher default) and expose via the Cloudflare
# tunnel (deploy/serve-public.sh). Set to 0.0.0.0 only if you instead front it
# with a firewall allowlist — the launcher refuses a public bind without
# DEMO_AUTH_PASSWORD unless DEMO_ALLOW_UNAUTH_PUBLIC=1 is set.
DEMO_MAIN_HOST=127.0.0.1
DEMO_MAIN_PORT=8000

# Show only the three shops in the App selector.
DEMO_VISIBLE_APP_IDS=shop_clothing,shop_cookware,shop_hardware
DEMO_APP_ID=shop_clothing

# StateFork / Waypoint backend. Leave the paths UNSET on a normal node: the
# launcher already defaults to $HOME/StateFork and $HOME/waypoint, which is
# where deploy.sh clones them. Only set these to point at a checkout somewhere
# else — a hardcoded absolute path here overrides the (correct) default and
# breaks the control plane on any machine with a different home directory.
# DEMO_STATEFORK_ROOT=/path/to/StateFork
# DEMO_STATEFORK_CWD=/path/to/StateFork
# WAYPOINT_SRC=/path/to/waypoint
DEMO_STATEFORK_METHOD=ckpt_build
CHECKPOINT_SESSIONS_DIR=/tmp/checkpoint-sessions-shopgym
DEMO_BRANCH_HOST=127.0.0.1
DEMO_BRANCH_PORT_START=8300

# Auto-teardown window for serve-public.sh (hours). Set 0 (or "never") to run
# indefinitely. For a supervised permanent run that also survives crashes and
# reboots, use deploy/install-service.sh (systemd) — it never auto-tears-down.
DEMO_TTL_HOURS=24

# Tunnel mode for deploy/install-service.sh (the permanent systemd path):
#   quick  Cloudflare quick tunnel (ephemeral URL; default)
#   named  Cloudflare named tunnel — stable hostname (also set CLOUDFLARE_TUNNEL_TOKEN)
#   none   control plane only — front it yourself (e.g. Tailscale Funnel for a free
#          stable *.ts.net URL; see the README recipe)
DEMO_TUNNEL_MODE=quick

# Idle auto-reset: after this many minutes with no activity, rebuild a clean
# shop (the same Reset the UI button does). A shop already at its clean initial
# state is never reset. Set 0 to disable. DEMO_IDLE_CHECK_SECONDS tunes how
# often the monitor checks (default 30).
DEMO_IDLE_RESET_MINUTES=10

# Max snapshots per workspace (each is a full CRIU dump on disk; Reset clears them).
DEMO_MAX_SNAPSHOTS=20
